# Variables d'environnement pour l'envoi des invitations via Brevo (fonction /api/invite).
# À renseigner dans Vercel : Settings → Environment Variables (NE PAS committer de vraies clés).

# Clé API Brevo (v3) — https://app.brevo.com/settings/keys/api
BREVO_API_KEY=

# Email expéditeur — doit être un expéditeur vérifié dans Brevo
BREVO_SENDER_EMAIL=

# Nom expéditeur (optionnel)
BREVO_SENDER_NAME=Sonate

# Base de données partagée (comptes, invitations, espaces, rapports) — Turso (libSQL).
# Créez une base sur https://turso.tech puis récupérez l'URL et un token.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Authentification du back-office.
# AUTH_SECRET : chaîne aléatoire longue (ex. `openssl rand -hex 32`) pour signer les sessions.
AUTH_SECRET=
# Compte admin de démarrage (permet de se connecter au back-office) :
ADMIN_EMAIL=
ADMIN_PASSWORD=
# Restriction optionnelle de l'auto-inscription (« Créer un compte »).
# Domaines email autorisés, séparés par des virgules. Vide = inscription ouverte.
SIGNUP_ALLOWED_DOMAINS=
